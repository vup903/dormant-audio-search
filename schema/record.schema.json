{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArchiveRecord",
  "description": "One record per recording. Provenance rule: anything a model produced is labeled ai_generated; the source_url must always be present so the original recording stays attached.",
  "type": "object",
  "required": [
    "id", "title", "date", "decade", "source_url", "rights",
    "audio_file", "duration_s", "asr", "transcript", "segments", "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "program": { "type": ["string", "null"] },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}(-\\d{2}(-\\d{2})?)?$",
      "description": "Broadcast date, as precise as the source metadata allows (YYYY, YYYY-MM, or YYYY-MM-DD)"
    },
    "decade": { "type": "string", "enum": ["1930s", "1940s", "1950s"] },
    "source_url": { "type": "string", "pattern": "^https?://" },
    "rights": {
      "type": "string",
      "minLength": 1,
      "description": "Rights statement as recorded from the archive.org item (e.g. 'public domain')"
    },
    "audio_file": { "type": "string", "minLength": 1 },
    "duration_s": { "type": "number", "exclusiveMinimum": 0 },
    "asr": {
      "type": "object",
      "required": ["model", "confidence", "ai_generated"],
      "additionalProperties": false,
      "properties": {
        "model": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "ai_generated": { "const": true }
      }
    },
    "transcript": { "type": "string" },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "text", "confidence"],
        "additionalProperties": false,
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "tags": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["term", "score", "ai_generated"],
        "additionalProperties": false,
        "properties": {
          "term": {
            "type": "string",
            "enum": [
              "war", "military", "election", "government", "international",
              "economy", "labor", "health", "crime", "disaster",
              "weather", "sports", "science", "education", "religion",
              "agriculture", "transportation", "civil-rights", "entertainment",
              "human-interest"
            ]
          },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "ai_generated": { "const": true }
        }
      }
    }
  }
}
